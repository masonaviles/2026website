# SQLAlchemy database URL
# Local:  sqlite+aiosqlite:///./data/mason.db
# Prod:   sqlite+aiosqlite:////data/mason.db   (4 slashes = absolute path on Fly volume)
DATABASE_URL=sqlite+aiosqlite:///./data/mason.db

# CORS allowlist (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://gitaddmason.dev

# Environment marker (development | production)
ENVIRONMENT=development

# AI / external services (Phase 4+)
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# Phase 1
TURNSTILE_SECRET=
RESEND_API_KEY=
